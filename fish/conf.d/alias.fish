# Alias config
alias cd='z' # Use zoxide insead cd
alias ls='eza --icons' # Use eza instead of ls
alias ll='eza -la --icons' # Long listing with eza
alias la='eza -a --icons' # Show all files with eza
alias cat='bat' # Use bat instead of cat
alias grep='rg' # Use ripgrep instead of grep
alias vi='nvim' # Use neovim instead of vi
#alias copy='win32yank.exe -i'

#GIT
alias gfa='git fetch --all' # Fetch from all remotes
alias gs='git status' # Git status
alias gaa='git add' # Git add
alias gc='git commit -m' # Git commit with message
alias gs='git switch' # Git switch branch
alias gps='git push'
alias gpl='git pull'

# Butler-CI-CLI
## General aliases
alias bci='butler-ci-cli' # Butler CI command
